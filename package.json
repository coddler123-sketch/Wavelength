{
  "name": "wavelength",
  "version": "1.7.6",
  "description": "Wavelength - Multi-Station Radio Player for Windows",
  "author": "Wavelength",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "smoke": "node scripts/smoke-check.js",
    "ui:audit": "electron scripts/ui-audit.js",
    "stations:check": "node scripts/validate-stations.js",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "test": "node scripts/smoke-check.js && node scripts/test.js",
    "verify": "npm run lint && npm run format:check && npm run stations:check && npm run ui:audit && npm test",
    "build:icon": "node scripts/build-icon.js",
    "build": "electron-builder --win --x64",
    "dist:clean": "powershell -NoProfile -Command \"if (Test-Path dist) { Remove-Item -Recurse -Force dist }\"",
    "build:clean": "npm run dist:clean && npm run build",
    "installer:smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/installer-smoke.ps1",
    "bump:patch": "node scripts/bump-version.js patch",
    "bump:minor": "node scripts/bump-version.js minor",
    "bump:major": "node scripts/bump-version.js major",
    "release:patch": "node scripts/release.js patch",
    "release:minor": "node scripts/release.js minor",
    "release:notes": "node scripts/release-notes.js",
    "release:gh": "node scripts/release-notes.js --gh-release",
    "e2e": "playwright test"
  },
  "build": {
    "appId": "com.wavelength.player",
    "productName": "Wavelength",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "portable": {
      "artifactName": "Wavelength-${version}-portable.exe"
    },
    "files": [
      "src/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "assets/",
        "to": "assets/"
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "coddler123-sketch",
      "repo": "Wavelength"
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "playwright": "^1.61.1",
    "png-to-ico": "^3.0.1",
    "prettier": "^3.9.4",
    "sharp": "^0.35.2"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
